<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="#00000000">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/glass_card_bg"
        android:orientation="vertical"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">

        <RelativeLayout
            android:id="@+id/cardTxn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp">

            <TextView
                android:id="@+id/txnIcon"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:gravity="center"
                android:text="💳"
                android:textSize="20sp"
                android:background="@drawable/icon_bg_blue" />

            <LinearLayout
                android:id="@+id/amountBlock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:orientation="vertical"
                android:gravity="end">

                <TextView
                    android:id="@+id/txnAmount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="- ₹0"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/dm_sans"
                    android:textColor="#F87171" />

                <TextView
                    android:id="@+id/txnBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="EXPENSE"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/dm_sans"
                    android:paddingStart="7dp"
                    android:paddingEnd="7dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:textColor="#F87171"
                    android:background="@drawable/badge_expense_bg" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/txnIcon"
                android:layout_toStartOf="@id/amountBlock"
                android:layout_centerVertical="true"
                android:orientation="vertical"
                android:paddingStart="12dp"
                android:paddingEnd="10dp">

                <TextView
                    android:id="@+id/txnTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Transaction"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/dm_sans"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/txnCategory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Category"
                    android:textColor="#99FFFFFF"
                    android:textSize="11sp"
                    android:fontFamily="@font/dm_sans"
                    android:layout_marginTop="2dp" />

                <TextView
                    android:id="@+id/txnDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Today"
                    android:textColor="#55FFFFFF"
                    android:textSize="10sp"
                    android:fontFamily="@font/dm_sans"
                    android:layout_marginTop="1dp" />
            </LinearLayout>

        </RelativeLayout>

       <View
            android:id="@+id/txnDivider"
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:layout_marginStart="18dp"
            android:layout_marginEnd="18dp"
            android:background="#15FFFFFF"
            android:visibility="gone" />

    </LinearLayout>

</androidx.cardview.widget.CardView>